{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",             // <- змінили з ESNext
    "moduleResolution": "node16",   // <- вже є

    "strict": true,
    "esModuleInterop": true,

    "types": [],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"]
}